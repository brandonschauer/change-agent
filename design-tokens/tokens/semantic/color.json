{
  "color": {
    "text": {
      "default":   { "$value": "{color.ink}",       "$type": "color", "$description": "Body text." },
      "muted":     { "$value": "{color.gray.700}",  "$type": "color", "$description": "Secondary / supporting text." },
      "on-brand":  { "$value": "{color.white}",     "$type": "color", "$description": "Text on brand/action surfaces." }
    },
    "background": {
      "default": { "$value": "{color.white}",    "$type": "color", "$description": "Raised cards & surfaces (top tier)." },
      "subtle":  { "$value": "{color.gray.50}",  "$type": "color", "$description": "Base page canvas (mid tier)." },
      "muted":   { "$value": "{color.gray.100}", "$type": "color", "$description": "Alternating section bands & neutral control fills (base tier)." }
    },
    "surface": {
      "brand":        { "$value": "{color.blue.500}",  "$type": "color", "$description": "Hero brand panel (Rare Blue)." },
      "chat-user":    { "$value": "{color.blue.50}",   "$type": "color", "$description": "User chat bubble." },
      "chat-agent":   { "$value": "{color.white}",     "$type": "color", "$description": "Agent chat surface (white + border to stay distinct from canvas)." }
    },
    "action": {
      "primary":       { "$value": "{color.blue.500}", "$type": "color", "$description": "Primary buttons / links." },
      "primary-hover": { "$value": "{color.blue.600}", "$type": "color", "$description": "Primary hover/active." }
    },
    "border": {
      "default": { "$value": "{color.gray.200}", "$type": "color", "$description": "Default hairline borders." },
      "strong":  { "$value": "{color.gray.700}", "$type": "color", "$description": "Emphasized borders / input rules." }
    },
    "feedback": {
      "error": { "$value": "{color.red.500}", "$type": "color", "$description": "Form validation errors." }
    },
    "focus": {
      "ring": { "$value": "{color.blue.500}", "$type": "color", "$description": "Focus-visible outline color." }
    }
  }
}
